DATABASE_URL="postgresql://user:password@localhost:5432/inbox_assistant?schema=public"
PORT=3001

# Worker AI (classification, next-action suggestions) — separate key/agent
WORKER_AI_API_KEY=sk-...
WORKER_AI_MODEL=gpt-4o-mini

# Verifier AI (audit next-action and completion) — separate key/agent
VERIFIER_AI_API_KEY=sk-...
VERIFIER_AI_MODEL=gpt-4o-mini

# Required in production: secret for signing session cookies (use a long random string)
SESSION_SECRET=your-long-random-secret-change-in-production

# Optional: allow frontend origin; comma-separated for multiple
# Production (Railway frontend): include https://task-router-dashboard-app-production.up.railway.app
CORS_ORIGIN=http://localhost:3000,https://task-router-dashboard-app-production.up.railway.app

# Storage (file/photo uploads)
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./uploads
# For S3: STORAGE_PROVIDER=s3, AWS_S3_BUCKET=, AWS_REGION=us-east-1, AWS_ACCESS_KEY_ID=, AWS_SECRET_ACCESS_KEY=

# Inbound email (email-to-inbox) — users forward emails to inbox+token@INBOUND_PARSE_DOMAIN
INBOUND_EMAIL_ENABLED=false
INBOUND_EMAIL_PROVIDER=resend
# Or: sendgrid, postmark
INBOUND_PARSE_DOMAIN=parse.yourdomain.com
# INBOUND_WEBHOOK_SECRET=  # optional for SendGrid
# Resend (when INBOUND_EMAIL_PROVIDER=resend):
RESEND_API_KEY=re_xxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx

# Email integration (future)
EMAIL_INTEGRATION=none
# Microsoft: MICROSOFT_GRAPH_TENANT_ID=, MICROSOFT_GRAPH_CLIENT_ID=, MICROSOFT_GRAPH_CLIENT_SECRET=
# Google: GOOGLE_CLIENT_ID=, GOOGLE_CLIENT_SECRET=

# Calendar API (future)
CALENDAR_MICROSOFT_ENABLED=false
CALENDAR_GOOGLE_ENABLED=false
# GOOGLE_CALENDAR_CLIENT_ID=, GOOGLE_CALENDAR_CLIENT_SECRET=
